{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["github>sanscfs/infra//renovate-presets/skynet-defaults.json"],
  "enabledManagers": ["pip_requirements", "pep621", "dockerfile"],
  "pip_requirements": {
    "fileMatch": ["docker/airflow/requirements\\.txt"]
  },
  "pep621": {
    "fileMatch": ["packages/[^/]+/pyproject\\.toml"]
  },
  "packageRules": [
    {
      "matchFileNames": ["packages/*/pyproject.toml"],
      "matchPackagePatterns": ["^skynet-"],
      "enabled": false
    }
  ]
}